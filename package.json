{
  "name": "fieldcore",
  "version": "0.1.0",
  "private": true,
  "description": "A modular real-time FRC field physics simulator with sensor-level vision simulation for WPILib robot code.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:logic": "node --experimental-strip-types scripts/drive-coordinate-tests.mjs",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@babylonjs/core": "^8.27.0",
    "@babylonjs/havok": "^1.3.10",
    "@babylonjs/loaders": "^8.27.0",
    "@material/web": "^2.4.0",
    "@msgpack/msgpack": "^3.1.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6"
  }
}
